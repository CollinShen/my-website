# ================================================================
# .env.example — copy this file to ".env" and fill in your values
#
# .env is NEVER committed to git (it holds secret passwords).
# .env.example IS committed so others know what variables are needed.
# ================================================================

# ----------------------------------------------------------------
# YOUR EMAIL SETTINGS (used to send contact form submissions to you)
#
# Option A — Gmail (easiest):
#   EMAIL_USER = your Gmail address
#   EMAIL_PASS = an "App Password" (NOT your normal Gmail password)
#   How to get a Gmail App Password:
#     1. Go to myaccount.google.com
#     2. Security → 2-Step Verification (must be ON)
#     3. Security → App Passwords
#     4. Generate one for "Mail" → copy the 16-char code here
#
# Option B — Any other SMTP provider (Mailgun, SendGrid, etc.):
#   Change EMAIL_HOST and EMAIL_PORT below to match your provider.
# ----------------------------------------------------------------

EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here

# The address where contact form messages will be SENT TO
# (usually the same as EMAIL_USER, but can be different)
EMAIL_TO=you@gmail.com

# ----------------------------------------------------------------
# SERVER PORT
# 3000 is fine for local development.
# On Render/Railway hosting they set PORT automatically — this is the fallback.
# ----------------------------------------------------------------
PORT=3000
